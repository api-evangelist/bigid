{
  "request": {
    "method": "GET",
    "url": "https://tenant.bigid.com/api/v1/ds-connections",
    "headers": {
      "Authorization": "<systemToken>"
    }
  },
  "response": {
    "status": 200,
    "body": {
      "status": "success",
      "statusCode": 200,
      "data": {
        "ds_connections": [
          {
            "name": "snowflake-prod",
            "type": "snowflake",
            "location": "tenant.snowflakecomputing.com",
            "enabled": "yes",
            "scanner_group": "default"
          },
          {
            "name": "s3-customer-files",
            "type": "s3-v2",
            "location": "s3://customer-files",
            "enabled": "yes",
            "scanner_group": "default"
          }
        ]
      }
    }
  }
}
