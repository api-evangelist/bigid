  "info": {
    "_postman_id": "13eddb0b-4b6c-48da-9407-45ecb5b10661",
    "name": "BigID Authentication API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Authenticate against a BigID deployment using either user credentials (username/password) or a long-lived user token. Exchange a user token for a short-lived system token (session token) used to authorize subsequent calls against the BigID REST API.\n\nContact Support:\n Name: BigID Support\n Email: support@bigid.com",
      "type": "text/plain"
    }
  }
