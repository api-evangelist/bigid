{
  "opencollection": "1.0.0",
  "info": {
    "name": "BigID Cluster Analysis API",
    "version": "1.0"
  },
  "items": [
    {
      "info": {
        "name": "Clusters",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "List Clusters",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{deployment}.bigid.com/api/v1/clusters",
            "params": [
              {
                "name": "filter",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              }
            ],
            "auth": {
              "type": "bearer",
              "token": "{{bearerToken}}"
            }
          },
          "docs": "Retrieve a list of clusters with optional filtering."
        }
      ]
    }
  ],
  "bundled": true
}